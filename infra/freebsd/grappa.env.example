# Grappa env file — chmod 600, owned by the grappa user.
# Loaded by /usr/local/etc/rc.d/grappa via the `grappa_env_file` rc.conf knob.
#
# Per CLAUDE.md "Security": SECRET_KEY_BASE, RELEASE_COOKIE, GRAPPA_ENCRYPTION_KEY,
# SASL passwords never logged, never committed. This file is a template only —
# fill in real values on the target host and `chmod 600`.

# ── Phoenix / Plug ─────────────────────────────────────────────────────────
# Generate with: bin/grappa eval 'Base.encode64(:crypto.strong_rand_bytes(48))'
# or (from a dev checkout): scripts/mix.sh phx.gen.secret
SECRET_KEY_BASE=REPLACE_ME

# Plug.Session signing salt (32+ random bytes).
# Generate with: scripts/mix.sh phx.gen.secret 32
SECRET_SIGNING_SALT=REPLACE_ME

# BEAM distribution cookie (any 32+ char random). Required when running
# release with `daemon` so `bin/grappa remote` can attach.
# Generate with: openssl rand -hex 32
RELEASE_COOKIE=REPLACE_ME

# ── Cloak vault key ────────────────────────────────────────────────────────
# Base64-encoded 32 bytes. Encrypts at-rest upstream credentials.
# Generate ONCE per deployment with:
#   _build/prod/rel/grappa/bin/grappa eval 'IO.puts(Base.encode64(:crypto.strong_rand_bytes(32)))'
# BACK THIS UP SEPARATELY. Lose the key = lose all stored credentials.
GRAPPA_ENCRYPTION_KEY=REPLACE_ME

# ── Web Push (VAPID) ───────────────────────────────────────────────────────
# Generate ONCE per deployment with:
#   _build/prod/rel/grappa/bin/grappa eval 'Grappa.Push.Vapid.gen_keypair() |> IO.inspect()'
VAPID_PUBLIC_KEY=REPLACE_ME
VAPID_PRIVATE_KEY=REPLACE_ME
VAPID_SUBJECT=mailto:operator@example.org

# ── Storage paths ──────────────────────────────────────────────────────────
# Absolute paths inside the jail. The DB + uploads dirs MUST be writable
# by the grappa user.
DATABASE_PATH=/home/grappa/grappa/runtime/grappa_prod.db
UPLOADS_STORAGE_ROOT=/home/grappa/grappa/runtime/uploads

# ── Phoenix host ───────────────────────────────────────────────────────────
PHX_HOST=grappa.bad.ass
PORT=4000

# Sqlite pool size (read concurrency). Defaults to 10 if unset.
POOL_SIZE=10

# Logger level: debug | info | notice | warning | error
LOG_LEVEL=info

# Logger file sink directory (Application.start attaches a
# :logger_std_h handler writing <LOG_DIR>/grappa.log, 10 MiB × 5
# rotation). Defaults to runtime/log next to the sqlite DB. Set to
# empty to disable the on-disk sink (rc.d still tees run_erl output
# to RELEASE_TMP regardless).
# LOG_DIR=/home/grappa/grappa/runtime/log

# ── Outbound v6 source-address pool ────────────────────────────────────────
# CSV of v6 addresses bound on this host/jail. IRC.Client picks a random
# entry per upstream connect so each peer IRC server sees a rotating
# rDNS identity. Empty = kernel-default selection (RFC 6724, deterministic).
GRAPPA_OUTBOUND_V6_POOL=2a03:4000:2:33c::9000,2a03:4000:2:33c::442,2a03:4000:2:33c::6699,2a03:4000:2:33c::80,2a03:4000:2:33c::444,2a03:4000:2:33c::888

# ── T31 admission captcha (optional) ───────────────────────────────────────
# GRAPPA_CAPTCHA_PROVIDER=disabled
# GRAPPA_CAPTCHA_SITE_KEY=
# GRAPPA_CAPTCHA_SECRET=

# ── BEAM resource caps (optional) ──────────────────────────────────────────
# GRAPPA_MAX_USERS=100
# GRAPPA_DIRTY_SCHEDULERS=
