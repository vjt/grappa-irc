#!/bin/sh
set -eu

prefix=/usr/local
bindir=
cc=${CC:-cc}
pkg_config=${PKG_CONFIG:-pkg-config}

usage() {
  cat <<'EOF'
usage: ./configure [OPTIONS]

Options:
  --prefix=PATH       installation prefix (default: /usr/local)
  --bindir=PATH       binary installation directory (default: PREFIX/bin)
  CC=cc               C compiler override
  PKG_CONFIG=cmd      pkg-config override
EOF
}

for arg in "$@"; do
  case "$arg" in
    --prefix=*) prefix=${arg#*=} ;;
    --bindir=*) bindir=${arg#*=} ;;
    --help|-h) usage; exit 0 ;;
    *) echo "configure: unknown option: $arg" >&2; usage >&2; exit 2 ;;
  esac
done

if [ -z "$bindir" ]; then
  bindir="$prefix/bin"
fi

check_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "configure: missing required command: $1" >&2
    exit 1
  fi
}

check_pkg() {
  if ! "$pkg_config" --exists "$1"; then
    echo "configure: missing required package: $1" >&2
    echo "configure: install the development package that provides $1.pc" >&2
    exit 1
  fi
}

check_compile() {
  name=$1
  code=$2
  libs=$3
  tmp_c=$(mktemp /tmp/shottino-conf.XXXXXX.c)
  tmp_o=$(mktemp /tmp/shottino-conf.XXXXXX)
  printf '%s\n' "$code" > "$tmp_c"
  if ! $cc -o "$tmp_o" "$tmp_c" $libs >/dev/null 2>&1; then
    rm -f "$tmp_c" "$tmp_o"
    echo "configure: failed compile/link test: $name" >&2
    exit 1
  fi
  rm -f "$tmp_c" "$tmp_o"
}

check_cmd "$cc"
check_cmd "$pkg_config"
check_pkg ncursesw
check_pkg openssl

ncurses_cflags=$($pkg_config --cflags ncursesw)
ncurses_libs=$($pkg_config --libs ncursesw)
openssl_cflags=$($pkg_config --cflags openssl)
openssl_libs=$($pkg_config --libs openssl)

check_compile "pthread" '#include <pthread.h>
int main(void) { pthread_t t = (pthread_t)0; (void)t; return 0; }' '-pthread'
check_compile "ncursesw" '#include <ncurses.h>
int main(void) { initscr(); endwin(); return 0; }' "$ncurses_libs"
check_compile "openssl" '#include <openssl/ssl.h>
int main(void) { SSL_library_init(); return 0; }' "$openssl_libs"

cat > config.mk <<EOF
# Generated by ./configure. Do not edit by hand.
PREFIX := $prefix
BINDIR := $bindir
CC := $cc
PKG_CONFIG := $pkg_config
CFLAGS_DEPS := $ncurses_cflags $openssl_cflags -pthread
LDLIBS_DEPS := $ncurses_libs $openssl_libs -pthread
EOF

echo "configure: wrote config.mk"
echo "configure: prefix=$prefix"
echo "configure: bindir=$bindir"
echo "configure: cc=$cc"
