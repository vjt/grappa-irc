# grappa — environment variables
#
# Copy to .env and fill in the prod-required block before
# `scripts/deploy.sh`. Dev (`docker compose up` with no profile) leaves
# the prod block unset and uses fixed dev values from config/dev.exs.

# Match host UID/GID so bind-mounted source files are owned correctly.
CONTAINER_UID=1000
CONTAINER_GID=1000

# Mix environment switch. `dev` for local hacking, `prod` for the
# deploy.sh stack. Phoenix expects an atom without the leading colon
# when read from env vars (just `prod`).
MIX_ENV=dev

# Host port publish for the grappa container. Defaults to loopback-only
# (`127.0.0.1:4000`) so the bouncer is unreachable from the LAN unless
# nginx (prod profile) is in front of it. Override examples:
#   GRAPPA_PUBLISH=192.168.53.12:4000   # bind to a LAN/VLAN IP
#   GRAPPA_PUBLISH=0.0.0.0:4000          # all interfaces (firewall it!)
#   GRAPPA_PUBLISH=127.0.0.1:14000       # alternate localhost port
GRAPPA_PUBLISH=127.0.0.1:4000

# Host port publish for the prod nginx container (only used when
# `--profile prod` is active). Default `3000:80` is the wildcard publish.
# Override to bind nginx to a specific LAN IP, typically alongside a
# DNS A record pointing at it. compose.override.yaml.example shows the
# canonical "bind nginx to LAN IP" + PHX_HOST + EXTRA_CHECK_ORIGINS
# triple — prefer the override file for that shape (avoids shell-quoting).
NGINX_PUBLISH=3000:80

# ─── Required for prod (`--profile prod` deploys) ─────────────────────────────
# Generate with:  scripts/mix.sh phx.gen.secret
SECRET_KEY_BASE=

# Plug.Session signing salt — Phoenix recommends 32+ random bytes.
# Generate with:  scripts/mix.sh phx.gen.secret 32
SECRET_SIGNING_SALT=

# Cloak vault key — base64-encoded 32 bytes. Encrypts at-rest upstream
# credentials (sasl_password etc.) in the sqlite DB.
# Generate ONCE per deployment with:
#   scripts/mix.sh grappa.gen_encryption_key
# Back this up separately! Losing the key = losing all stored credentials.
GRAPPA_ENCRYPTION_KEY=

# ─── Optional in prod (sensible defaults applied) ─────────────────────────────
# Ecto pool size. Defaults to 10. Sqlite is single-writer; raising pool size
# helps read concurrency, not write throughput.
POOL_SIZE=10

# Phoenix HTTP listener port. Defaults to 4000.
PORT=4000

# Logger level: :debug | :info | :notice | :warning | :error. Prod default :info.
# Read via String.to_existing_atom/1 — must be a known Logger level atom.
LOG_LEVEL=info

# Public hostname the bouncer is reached at via nginx. Defaults to
# grappa.bad.ass (the home-LAN deployment). Override here if your
# deployment lives elsewhere — Phoenix's `check_origin` rejects
# WebSocket handshakes whose Origin header doesn't match this.
PHX_HOST=grappa.bad.ass

# BEAM resource caps (see bin/start.sh). Unset → defaults applied
# (GRAPPA_MAX_USERS=100, GRAPPA_DIRTY_SCHEDULERS=$(nproc)).
# GRAPPA_MAX_USERS=100
# GRAPPA_DIRTY_SCHEDULERS=

# ─── T31 admission captcha (optional — leave unset for Disabled provider) ─────
# config/runtime.exs reads these env vars to populate :grappa, :admission
# config (provider, secret, public site key). Provider absent / unknown =
# Disabled (boots clean, never emits captcha_required at the boundary).
# Non-Disabled providers HARD-CRASH at boot if secret or site_key is
# missing/blank (Grappa.Admission.Config.boot/0 invariant).
#
# When enabling, also ensure infra/nginx.conf CSP allowlist covers the
# provider host. Drift breaks deploy in a way only real-browser e2e
# catches (per CP11 S22 deploy-time bug post-mortem).
#
# Example site_key below is the registered prod Turnstile widget for
# grappa.bad.ass — replace with your own for local/other deployments.
# GRAPPA_CAPTCHA_PROVIDER=turnstile  # or hcaptcha; absent = disabled
# GRAPPA_CAPTCHA_SITE_KEY=0x4AAAAAADIVjqhMXybemB6v
# GRAPPA_CAPTCHA_SECRET=
