# grappa — environment variables
#
# Copy to .env and fill in.

# Match host UID/GID so bind-mounted source files are owned correctly.
CONTAINER_UID=1000
CONTAINER_GID=1000

# Mix environment for `docker compose up` (dev compose).
# Override to :prod when running compose.prod.yaml. Phoenix expects an atom
# without the leading colon when read from env vars (just `prod`).
MIX_ENV=dev

# ─── Required for prod (compose.prod.yaml) ────────────────────────────────────
# Generate with:  scripts/mix.sh phx.gen.secret
SECRET_KEY_BASE=

# Distributed Erlang cookie. Random ~64-char hex string.
# Generate with:  openssl rand -hex 32
RELEASE_COOKIE=
