# grappa — environment variables
#
# Copy to .env and fill in the prod-required block before
# `scripts/deploy.sh`. Dev (`docker compose up` with no profile) leaves
# the prod block unset and uses fixed dev values from config/dev.exs.

# Match host UID/GID so bind-mounted source files are owned correctly.
CONTAINER_UID=1000
CONTAINER_GID=1000

# Mix environment switch. `dev` for local hacking, `prod` for the
# deploy.sh stack. Phoenix expects an atom without the leading colon
# when read from env vars (just `prod`).
MIX_ENV=dev

# Host port publish for the grappa container. Defaults to loopback-only
# (`127.0.0.1:4000`) so the bouncer is unreachable from the LAN unless
# nginx (prod profile) is in front of it. Override examples:
#   GRAPPA_PUBLISH=192.168.53.12:4000   # bind to a LAN/VLAN IP
#   GRAPPA_PUBLISH=0.0.0.0:4000          # all interfaces (firewall it!)
#   GRAPPA_PUBLISH=127.0.0.1:14000       # alternate localhost port
GRAPPA_PUBLISH=127.0.0.1:4000

# Host port publish for the prod nginx container (only used when
# `--profile prod` is active). Default `3000:80` is the wildcard publish.
# Override to bind nginx to a specific LAN IP, typically alongside a
# DNS A record pointing at it. compose.override.yaml.example shows the
# canonical "bind nginx to LAN IP" + PHX_HOST + EXTRA_CHECK_ORIGINS
# triple — prefer the override file for that shape (avoids shell-quoting).
NGINX_PUBLISH=3000:80

# ─── Required for prod (`--profile prod` deploys) ─────────────────────────────
# Generate with:  scripts/mix.sh phx.gen.secret
SECRET_KEY_BASE=

# Plug.Session signing salt — Phoenix recommends 32+ random bytes.
# Generate with:  scripts/mix.sh phx.gen.secret 32
SECRET_SIGNING_SALT=

# Cloak vault key — base64-encoded 32 bytes. Encrypts at-rest upstream
# credentials (sasl_password etc.) in the sqlite DB.
# Generate ONCE per deployment with:
#   scripts/mix.sh grappa.gen_encryption_key
# Back this up separately! Losing the key = losing all stored credentials.
GRAPPA_ENCRYPTION_KEY=

# VAPID keypair — push notifications cluster B2 (2026-05-14).
# Required for Web Push delivery (RFC 8292).
# Generate ONCE per deployment with:
#   scripts/mix.sh grappa.gen_vapid
# Bootstrap raises at boot if either is missing. Losing the PRIVATE
# key invalidates every existing browser push subscription — rotation
# forces every user to re-toggle the master switch in cic settings.
# Operators typically pin these in compose.override.yaml's grappa
# environment block instead of .env (see compose.override.yaml.example).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Optional — `sub` claim in the VAPID JWT, surfaced to vendor push
# services so they can contact the operator about delivery issues.
# Defaults to mailto:admin@example.org if unset.
# VAPID_SUBJECT=mailto:you@example.org

# Erlang distribution cookie. Gates `bin/grappa remote-shell` access
# (T cluster T-2, 2026-05-16). The dev default
# `grappa-dev-cookie-do-not-use-in-prod` is hardcoded in compose.yaml
# so `docker compose up` works clone-and-go; runtime.exs HARD-CRASHES
# at boot in MIX_ENV=prod when this is unset OR equals the dev sentinel.
# Generate a real value with:
#   openssl rand -hex 32
# Threat model: anyone with `docker exec` privilege can `printenv` the
# cookie inside the container, AND any container attached to the
# `grappa_internal` bridge (today: nginx + cicchetto-build oneshot)
# with Erlang installed could `:net_adm.ping(:grappa@grappa)` if it
# knew the cookie. Distribution port is never published to the host —
# the cookie is a same-host operator gate (sname-collision-prevention
# + "you meant to do this") not a network boundary. Rotation requires
# a COLD deploy and invalidates all live admin remsh sessions.
# Leave commented in dev (compose.yaml default applies); MUST be set
# for prod deploys.
# RELEASE_COOKIE=

# ─── Optional in prod (sensible defaults applied) ─────────────────────────────
# Ecto pool size. Defaults to 10. Sqlite is single-writer; raising pool size
# helps read concurrency, not write throughput.
POOL_SIZE=10

# Phoenix HTTP listener port. Defaults to 4000.
PORT=4000

# UX-6-B1 (2026-05-20): embedded image uploader storage directory.
# Defaults to `runtime/uploads` (sibling of the sqlite DB; covered by
# the existing `./runtime:/app/runtime` bind-mount). Override only if
# disk-policy requires a separate volume. Cap admin-tunes per-file +
# global-disk ceilings live in `server_settings` table (admin REST).
UPLOADS_STORAGE_ROOT=runtime/uploads

# Outbound v6 source-address pool. CSV of IPv6 addresses bound on
# the host/jail; IRC.Client picks a random entry per upstream
# connect so each peer IRC server sees a rotating rDNS identity.
# Useful when the host has multiple v6 addresses with vanity
# reverse-DNS. Empty = kernel-default RFC 6724 source selection
# (no behavior change for single-IP deployments). A typo in the
# CSV crashes boot loudly rather than silently falling back.
# Example:
#   GRAPPA_OUTBOUND_V6_POOL=2a03:4000:2:33c::9000,2a03:4000:2:33c::442
GRAPPA_OUTBOUND_V6_POOL=

# Logger level: :debug | :info | :notice | :warning | :error. Prod default :info.
# Read via String.to_existing_atom/1 — must be a known Logger level atom.
LOG_LEVEL=info

# Logger file sink directory. Application.start attaches a
# :logger_std_h handler writing <LOG_DIR>/grappa.log (10 MiB × 5
# rotation, same formatter + metadata as :console). Default
# `/app/runtime/log` lives under the bind-mounted ./runtime/ so the
# host sees the file. Set empty to disable the on-disk sink (stdout
# still flows to docker logs).
LOG_DIR=/app/runtime/log

# Public hostname the bouncer is reached at via nginx. Defaults to
# grappa.bad.ass (the home-LAN deployment). Override here if your
# deployment lives elsewhere — Phoenix's `check_origin` rejects
# WebSocket handshakes whose Origin header doesn't match this.
PHX_HOST=grappa.bad.ass

# BEAM resource caps (see bin/start.sh). Unset → defaults applied
# (GRAPPA_MAX_USERS=100, GRAPPA_DIRTY_SCHEDULERS=$(nproc)).
# GRAPPA_MAX_USERS=100
# GRAPPA_DIRTY_SCHEDULERS=

# ─── T31 admission captcha (optional — leave unset for Disabled provider) ─────
# config/runtime.exs reads these env vars to populate :grappa, :admission
# config (provider, secret, public site key). Provider absent / unknown =
# Disabled (boots clean, never emits captcha_required at the boundary).
# Non-Disabled providers HARD-CRASH at boot if secret or site_key is
# missing/blank (Grappa.Admission.Config.boot/0 invariant).
#
# When enabling, also ensure infra/nginx.conf CSP allowlist covers the
# provider host. Drift breaks deploy in a way only real-browser e2e
# catches (per CP11 S22 deploy-time bug post-mortem).
#
# `GRAPPA_CAPTCHA_SITE_KEY` is the public widget identifier issued by
# the captcha provider for your domain — embedded in the served HTML
# and safe to publish. Replace the placeholder below with your own.
# GRAPPA_CAPTCHA_PROVIDER=turnstile  # or hcaptcha; absent = disabled
# GRAPPA_CAPTCHA_SITE_KEY=0xYOUR_TURNSTILE_SITE_KEY_HERE
# GRAPPA_CAPTCHA_SECRET=
