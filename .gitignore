# ── Elixir / Erlang
/_build/
/cover/
/coverage/
/deps/
/doc/
/.fetch
/.hex/
/.mix/
/.cache/
/.sobelow/
erl_crash.dump
*.ez
*.beam
.elixir_ls/
/.dialyxir_*
*.plt

# ── PLT cache (Dialyzer)
priv/plts/*.plt
priv/plts/*.plt.hash

# ── Releases
/grappa-*.tar
/grappa-*.tar.gz
/release/

# ── Mix-generated
*.zip

# ── Local config / state (NEVER commit secrets or live DB)
/grappa.toml
/grappa_dev.db
/grappa_test*.db*
*.db-shm
*.db-wal
*.db-journal
/runtime/*
!/runtime/.gitkeep
# Bake bind-mount target dirs so a fresh `git clone` doesn't hit
# Docker auto-creating them as `root:root` on first
# `docker compose --profile prod up cicchetto-build` (container UID
# 1000 then fails to write Vite's `dist/` or bun's cache).
!/runtime/cicchetto-dist/
/runtime/cicchetto-dist/*
!/runtime/cicchetto-dist/.gitkeep
!/runtime/bun-cache/
/runtime/bun-cache/*
!/runtime/bun-cache/.gitkeep

# ── Docker / env
.env
.env.local
*.local

# ── Personal compose overrides (machine-specific bindings, hostnames).
# Examples are committed (compose.{,prod.}override.yaml.example);
# real overrides stay local.
/compose.override.yaml
/compose.prod.override.yaml

# ── Local cluster worktrees (self-contained, machine-specific)
/.worktrees/

# ── Ephemeral implementation plans (scratch, per-feature; deleted at
# feature completion — durable rationale goes to docs/DESIGN_NOTES.md
# first). See CLAUDE.md "Docs map". docs/superpowers/specs/ stays tracked.
/docs/plans/
/docs/superpowers/plans/

# ── Claude Code session state (locks, scratch, output)
# Skills + settings.json are repo-shared content; everything else
# (locks, scratch, settings.local.json) stays local.
.claude/*
!.claude/skills/
!.claude/settings.json

# ── Superpowers brainstorm session artifacts (mockups, state events)
.superpowers/

# ── Editors / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~
*.iml
.vscode-test/

# ── Node / PWA (cicchetto, future)
/node_modules/
/dist/
/.vite/
/.svelte-kit/
*.log

# ── Native terminal shottino build artifacts
/frontends/shottino/shottino

# GitHub CLI config
.gh

# orchestrator handoff brain (ephemeral run state, durable across reboot, never committed)
.orchestrate/
