# grappa — compose personal override (gitignored as compose.override.yaml).
#
# Auto-loaded by scripts/_lib.sh when present. Do NOT commit your real
# override — it's pinned to your machine's interface, hostname, and DNS.
#
# Single committed compose.yaml ships safe defaults: grappa publishes on
# 127.0.0.1:4000 (loopback only). Use overrides to bind to a LAN/VLAN IP
# or pin prod-specific environment.
#
# Two example shapes — pick one or merge both depending on dev vs prod
# usage on this host. Most operators want the prod block; dev typically
# leaves the loopback default in place.
#
# `ports: !override` replaces compose.yaml's wildcard publish with the
# IP-bound publish below. Without !override, compose merges port lists
# by appending (both bindings would coexist). `!reset` would drop
# ports entirely without re-adding ours.

services:
  # Dev shape — bind grappa to a LAN IP for testing from another device.
  # Drop this block if you only ever run dev on loopback.
  # grappa:
  #   ports: !override
  #     - "192.168.53.12:4000:4000"

  # Prod shape — bind nginx to your LAN/VLAN IP (default committed shape
  # is wildcard :3000) and pin Phoenix's `check_origin` allowlist via
  # PHX_HOST + EXTRA_CHECK_ORIGINS. Set MIX_ENV=prod in .env (or the
  # invoking shell) so compose.yaml's `${MIX_ENV:-dev}` resolves to prod.
  nginx:
    ports: !override
      - "192.168.53.12:80:80"

  grappa:
    environment:
      PHX_HOST: voygrappa.bad.ass
      # EXTRA_CHECK_ORIGINS: WS `check_origin` extras AND (with PHX_HOST,
      # #324) the deployment's HTTP host-alias set — every hostname nginx
      # reverse-proxies to this ONE instance. List a sibling public vhost
      # here (comma-separated) and cic's media-link viewer opens uploads
      # minted under it too; no cic redeploy, no second list.
      EXTRA_CHECK_ORIGINS: "http://192.168.53.12"
      # Push notifications cluster B2 (2026-05-14). Generate once per
      # deployment with `scripts/mix.sh grappa.gen_vapid` and paste
      # the output below. Required: VAPID_PUBLIC_KEY +
      # VAPID_PRIVATE_KEY (Bootstrap raises at boot if either is
      # missing). Optional: VAPID_SUBJECT (default
      # mailto:admin@example.org).
      #
      # Keys are non-secret in the operational sense (the public key
      # ships in every PushSubscription request), but losing the
      # PRIVATE key invalidates every existing push subscription —
      # rotation forces every user to re-toggle the master switch in
      # cic settings. Back up the keypair if you care about that.
      VAPID_PUBLIC_KEY: "BJk...replace-with-output-of-grappa.gen_vapid..."
      VAPID_PRIVATE_KEY: "z3p...replace-with-output-of-grappa.gen_vapid..."
      # VAPID_SUBJECT: "mailto:you@example.org"
