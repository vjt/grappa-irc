# grappa — operator config
#
# Copy to grappa.toml and edit. Phase 1 is single-user, single-network per
# user (hardcoded — no auth). Phase 2 replaces this static config with
# dynamic per-user state in the database.

[server]
listen = "0.0.0.0:4000"

[[users]]
name = "vjt"

[[users.networks]]
id = "azzurra"
host = "irc.azzurra.chat"
port = 6697
tls = true
nick = "vjt-grappa"
# sasl_password = "your-nickserv-password"
autojoin = ["#sniffo", "#it-opers"]

# Add more networks per user:
# [[users.networks]]
# id = "libera"
# host = "irc.libera.chat"
# port = 6697
# tls = true
# nick = "vjt-grappa"
# autojoin = ["##italian-grappa"]
