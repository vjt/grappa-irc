{
  "name": "cicchetto",
  "version": "0.0.1",
  "private": true,
  "description": "Grappa PWA — irssi-shaped browser client over REST + Phoenix Channels.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "check": "biome check src && tsc --noEmit",
    "check:fix": "biome check --write src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@solidjs/router": "^0.16.1",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jsdom": "^28.0.1",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.5"
  }
}
