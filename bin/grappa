#!/usr/bin/env bash
# bin/grappa — host-side operator dispatcher.
#
# One verb per task. Run from any worktree of the grappa repo:
#
#   bin/grappa help                     list verbs
#   bin/grappa help <verb>              per-verb help
#   bin/grappa <verb> [args]            dispatch
#
# The container IS the runtime. Boot-time verbs (create-user,
# bind-network, etc.) delegate to mix tasks inside the container via
# scripts/mix.sh (which auto-detects MIX_ENV). Live-state verbs
# (delete-visitor, reap-visitors, list-*) and remote-shell attach to
# the live BEAM via Erlang distribution: `elixir --rpc-eval grappa@grappa`
# evaluates a `Grappa.Operator.<verb>(...)` expression on the running
# node (per T-2). Operator-side bookkeeping lives in lib/grappa/operator.ex
# so the bash dispatcher stays a thin shell — one feature, one code
# path, every door.
#
# Verb name policy: kebab-case on the command line, snake_case for the
# underlying mix task (grappa.create_user, etc.). Mapping is mechanical
# (tr - _) — no per-verb hardcoding.
#
# Verb table: a single `declare -Ag VERBS` map (below) is the source
# of truth for dispatch + help. Per-verb metadata is encoded as a
# pipe-separated tuple `kind|target|group|description`:
#   - kind:    boot|rpc|attach|debug|meta
#   - target:  for boot, the mix task name; for rpc, the
#              `Grappa.Operator.fn!()` expression body (sans args);
#              for attach/debug/meta, the verb name itself (handled
#              by the per-verb function `verb_<snake>`).
#   - group:   help-banner section header
#   - description: one-line summary for help-banner
#
# Adding a new verb is now a TWO-touchpoint change: one VERBS entry +
# one verb_<snake>() function (boot verbs can drop the explicit
# function by using the default boot-handler).

set -euo pipefail

. "$(dirname "$0")/../scripts/_lib.sh"

# Test seam: bats overrides SCRIPTS_DIR to point at a tmpdir with
# fake scripts/mix.sh. Production calls inherit the real scripts/.
SCRIPTS_DIR="${SCRIPTS_DIR:-$SRC_ROOT/scripts}"

# Run every `docker compose` from the MAIN repo root, like every sibling
# script. Two things break otherwise when invoked from a worktree (this
# dispatcher's docstring promises "run from any worktree"):
#   1. compose has no top-level `name:`, so the project defaults to the
#      CWD basename — from a worktree that's the worktree dir, a DIFFERENT
#      project than the live container (created under the main-repo name),
#      so `exec grappa` can't find it.
#   2. COMPOSE_ARGS carries a RELATIVE `-f compose.override.yaml` resolved
#      against CWD; the gitignored override lives only at the main repo,
#      so from a worktree docker errors "no such file".
# `cd "$REPO_ROOT"` (the main repo, resolved via git-common-dir in _lib.sh)
# fixes both. SCRIPTS_DIR is already absolute, so boot verbs are unaffected.
cd "$REPO_ROOT"

# --- verb table -----------------------------------------------------------
#
# kebab-name → kind|target|group|description
#
# Ordering inside each group section is the order verbs appear in
# `help_top()`. Across groups, ordering is preserved by the explicit
# GROUP_ORDER array below.
declare -Ag VERBS=(
    [create-user]="boot|grappa.create_user|boot|create a Grappa user account"
    [bind-network]="boot|grappa.bind_network|boot|bind a (user, network) credential"
    [add-server]="boot|grappa.add_server|boot|add a server entry to a network"
    [remove-server]="boot|grappa.remove_server|boot|remove a server entry from a network"
    [set-network-caps]="boot|grappa.set_network_caps|boot|set per-network session caps"
    [unbind-network]="boot|grappa.unbind_network|boot|remove a (user, network) credential"
    [update-network-credential]="boot|grappa.update_network_credential|boot|edit autojoin / nick / SASL fields"
    [seed-scrollback]="boot|grappa.seed_scrollback|boot|seed dev scrollback"
    [gen-encryption-key]="boot|grappa.gen_encryption_key|boot|generate a Cloak.Vault key"
    [gen-vapid]="boot|grappa.gen_vapid|boot|generate a VAPID keypair (push)"

    [delete-visitor]="rpc|Grappa.Operator.delete_visitor!|rpc|terminate + delete a visitor (sync)"
    [reap-visitors]="rpc|Grappa.Operator.reap_visitors!|rpc|force-run the visitor reaper"
    [list-sessions]="rpc|Grappa.Operator.list_sessions_text!|rpc|inspect the live session registry"
    [list-credentials]="rpc|Grappa.Operator.list_credentials_text!|rpc|list cred bindings + state"
    [list-visitors]="rpc|Grappa.Operator.list_visitors_text!|rpc|list active visitor rows"

    [remote-shell]="attach|remote-shell|attach|iex --remsh against the live BEAM"

    [open-db]="debug|open-db|debug|interactive sqlite3 against active env (RW)"
    [shell]="debug|shell|debug|bash inside the grappa container"

    [help]="meta|help|meta|this banner / per-verb help"
)

declare -ag GROUP_ORDER=(boot rpc attach debug meta)
declare -Ag GROUP_HEADERS=(
    [boot]="Boot-time verbs (mix tasks; auto-detect MIX_ENV from container):"
    [rpc]="Live-state verbs (--rpc-eval against the live BEAM):"
    [attach]="Live-state attach:"
    [debug]="Debug verbs:"
    [meta]="Meta:"
)

# Field accessor — `verb_field <kebab> <field-index>`. Field indices:
# 1=kind, 2=target, 3=group, 4=description. Returns empty if verb is
# unknown (caller's responsibility to gate on `[ -n "${VERBS[$v]:-}" ]`).
verb_field() {
    local entry="${VERBS[$1]:-}"
    [ -z "$entry" ] && return 0
    cut -d'|' -f"$2" <<<"$entry"
}

# Kebab → snake conversion. Pure mechanical — no per-verb hardcoding.
kebab_to_snake() { tr '-' '_' <<<"$1"; }

# --- helpers --------------------------------------------------------------

mix_task() {
    # Auto-detect MIX_ENV from the live container; scripts/mix.sh handles
    # the override flag if the operator wants explicit env. Boot-time
    # verbs typically run against the container the operator is deploying
    # against, so auto-detect is the right default.
    exec "$SCRIPTS_DIR/mix.sh" "$@"
}

# Run a Grappa.Operator expression on the live BEAM via Erlang dist.
# Same shape as `remote-shell --batch -e <expr>` — mirror T-2 exactly so
# the operator-verb surface and the introspection surface share one
# transport. The expression is evaluated on the REMOTE node (`--rpc-eval`),
# NOT on the client (`--remsh -e` would evaluate client-side, defeating
# the point of attaching to the live tree).
rpc_eval() {
    local expr=$1
    exec docker compose "${COMPOSE_ARGS[@]}" exec -T grappa sh -c \
        'exec elixir --sname "admin-$$" --cookie "$RELEASE_COOKIE" --rpc-eval grappa@grappa "$1"' \
        -- "$expr"
}

die_unknown_verb() {
    printf 'bin/grappa: unknown verb %q\n' "$1" >&2
    printf 'Run `bin/grappa help` for the full verb table.\n' >&2
    exit 64
}

# --- per-verb implementations --------------------------------------------
#
# Boot verbs use the generic `dispatch_boot` handler (kebab → mix task
# name from the VERBS table). RPC verbs that take a positional argument
# need a bespoke `verb_<snake>` function; nullary RPC verbs route
# through the generic `dispatch_rpc` handler.

dispatch_boot() {
    local verb=$1; shift
    local task
    task="$(verb_field "$verb" 2)"
    mix_task "$task" "$@"
}

dispatch_rpc() {
    local verb=$1; shift
    if [ $# -ne 0 ]; then
        printf 'bin/grappa: %s takes no arguments\n' "$verb" >&2
        exit 64
    fi
    local fn
    fn="$(verb_field "$verb" 2)"
    rpc_eval "${fn}()"
}

verb_delete_visitor() {
    if [ $# -ne 1 ]; then
        printf 'Usage: bin/grappa delete-visitor <uuid>\n' >&2
        exit 64
    fi
    local id=$1
    rpc_eval "Grappa.Operator.delete_visitor!(\"$id\")"
}

verb_remote_shell() {
    # T-A2 / T-2: live-BEAM attach via Erlang distribution. Cookie is
    # sourced INSIDE the container's `sh -c` (no host needs to know it);
    # admin sname uses $$ for per-invocation uniqueness.
    #
    # Interactive uses `iex --remsh` (REPL attaches to the live node).
    # Batch uses `elixir --rpc-eval`: `iex --remsh -e "<expr>"` evaluates
    # the expression in the CLIENT node before attaching, defeating the
    # operator's intent (Process.list() returns 60-ish vergine procs
    # rather than the live tree's 140+). `--rpc-eval` evaluates on the
    # REMOTE node and prints the result, no shell attached.
    case "${1:-}" in
        --batch)
            shift
            if [ "${1:-}" != "-e" ] || [ -z "${2:-}" ]; then
                printf 'remote-shell --batch requires `-e <expr>`.\n' >&2
                printf 'Usage: bin/grappa remote-shell --batch -e <expr>\n' >&2
                exit 64
            fi
            rpc_eval "$2"
            ;;
        "")
            exec docker compose "${COMPOSE_ARGS[@]}" exec grappa sh -c \
                'exec iex --sname "admin-$$" --cookie "$RELEASE_COOKIE" --remsh grappa@grappa'
            ;;
        *)
            printf 'remote-shell: unknown arg %q\n' "$1" >&2
            printf 'Usage: bin/grappa remote-shell [--batch -e <expr>]\n' >&2
            exit 64
            ;;
    esac
}

verb_open_db() {
    # WARNING: opens RW. scripts/db.sh is the ambient-safe RO alternative
    # for casual prod queries. Auto-detects active env's DB file via the
    # shared _lib.sh probe (single source of truth with scripts/mix.sh).
    local env db
    env="$(detect_mix_env)"
    env="${env:-dev}"
    db="/app/runtime/grappa_${env}.db"
    exec docker compose "${COMPOSE_ARGS[@]}" exec grappa sqlite3 "$db" "$@"
}

verb_shell() {
    exec docker compose "${COMPOSE_ARGS[@]}" exec grappa bash
}

# --- per-verb help -------------------------------------------------------
#
# Boot verbs delegate to `mix help grappa.<task>` (mix's built-in reads
# @shortdoc/@moduledoc). Live-state + debug verbs have inline heredocs.

help_boot_verb() {
    local task=$1
    exec "$SCRIPTS_DIR/mix.sh" --env=dev help "$task"
}

verb_help_delete_visitor() { cat <<'EOF'
delete-visitor <uuid>
    Synchronously terminate the visitor's Session.Server and delete
    the DB row, freeing the SessionRegistry cap slot in the same call.
    CASCADE wipes visitor_channels, messages, accounts_sessions,
    query_windows, push_subscriptions, user_settings, read_cursors.

    Unknown uuid: raises Ecto.NoResultsError; bin/grappa exits non-zero.
EOF
}

verb_help_reap_visitors() { cat <<'EOF'
reap-visitors
    Force-run Grappa.Visitors.Reaper.sweep/0 on demand. The scheduled
    tick runs every 60s; this verb is the operator-on-demand variant.
EOF
}

verb_help_list_sessions() { cat <<'EOF'
list-sessions
    Print every live Session.Server in Grappa.SessionRegistry as a
    tab-separated table. Columns:
        subject_kind  subject_id  network_id  pid  alive  mailbox_len  memory_kb
    The mailbox_len + memory_kb columns surface bloat / leaks on a
    stuck session.
EOF
}

verb_help_list_credentials() { cat <<'EOF'
list-credentials
    Print every bound (user, network) credential as a tab-separated
    table. Columns:
        user_id  network_slug  nick  state  connection_state_reason
EOF
}

verb_help_list_visitors() { cat <<'EOF'
list-visitors
    Print every active visitor as a tab-separated table. Columns:
        id  nick  network_slug  expires_at  identified  inserted_at
    Active = identified (never expires) OR anon with expires_at > now.
EOF
}

verb_help_remote_shell() { cat <<'EOF'
remote-shell [--batch -e <expr>]
    Attach to the live BEAM via Erlang distribution.

    Interactive (default — `iex --remsh`):
        bin/grappa remote-shell

    Batch (`elixir --rpc-eval`; eval one expression on the REMOTE
    node and exit):
        bin/grappa remote-shell --batch -e 'Process.list() |> length()'

    Note: `iex --remsh -e <expr>` evaluates in the CLIENT node
    BEFORE attaching the shell, which defeats `Process.list()` /
    `:sys.get_state(...)` / etc. — the point of remote-shell is to
    introspect the LIVE supervisor tree. `--rpc-eval` runs on the
    remote and prints the result.

    Distribution is internal to the container's network namespace —
    no host port is exposed. RELEASE_COOKIE is sourced from the
    container's environment (see compose.yaml + .env.example) and
    gates `iex --remsh` access. Anyone with `docker exec` privilege
    on the host can already read the cookie via `printenv`, AND any
    container attached to the `grappa_internal` bridge with Erlang
    installed could connect if it knew the cookie. The cookie is a
    same-host operator gate (sname-collision-prevention + "you
    meant to do this") rather than a network boundary.
EOF
}

verb_help_open_db() { cat <<'EOF'
open-db [sqlite3 args...]
    Open an interactive sqlite3 shell against the active env's DB
    inside the container. Detects MIX_ENV from the running container.

    WARNING: RW. Use scripts/db.sh for ambient-safe RO access.
EOF
}

verb_help_shell() { cat <<'EOF'
shell
    Drop into a bash shell inside the running grappa container.
    Requires the container to be up.
EOF
}

verb_help_help() { cat <<'EOF'
help [verb]
    With no arg, print the verb table grouped by category.
    With a verb, print that verb's help text.
EOF
}

# --- top-level help banner -----------------------------------------------
#
# Generated from the VERBS table — no manual list to keep in lockstep
# with the dispatch table.

help_top() {
    printf 'bin/grappa — host-side operator dispatcher\n\n'
    printf 'Usage:\n'
    printf '    bin/grappa <verb> [args...]\n'
    printf '    bin/grappa help [verb]\n\n'

    local group verb kind target g desc
    for group in "${GROUP_ORDER[@]}"; do
        printf '%s\n' "${GROUP_HEADERS[$group]}"
        # Iterate in insertion order via the GROUP_ORDER+VERBS pairing.
        # Bash 4 associative arrays don't preserve insertion order on
        # iteration, so we walk a manually-ordered display list per group.
        for verb in "${VERB_DISPLAY_ORDER[@]}"; do
            g="$(verb_field "$verb" 3)"
            [ "$g" = "$group" ] || continue
            desc="$(verb_field "$verb" 4)"
            printf '    %-28s %s\n' "$verb" "$desc"
        done
        printf '\n'
    done
}

# Display order — matches the original help_top()'s curated ordering
# per group. Bash 4 associative-array iteration is unordered, so we
# carry an explicit ordered list. New verbs: add to VERBS map AND
# here in the appropriate group's position.
declare -ag VERB_DISPLAY_ORDER=(
    create-user
    bind-network
    add-server
    remove-server
    set-network-caps
    unbind-network
    update-network-credential
    seed-scrollback
    gen-encryption-key
    gen-vapid
    delete-visitor
    reap-visitors
    list-sessions
    list-credentials
    list-visitors
    remote-shell
    open-db
    shell
    help
)

# --- dispatch ------------------------------------------------------------

# Per-verb help dispatch. Boot verbs delegate to `mix help grappa.<task>`;
# all others have an explicit `verb_help_<snake>` function.
dispatch_help() {
    if [ $# -eq 0 ]; then
        help_top
        exit 0
    fi
    local verb=$1
    [ -n "${VERBS[$verb]:-}" ] || die_unknown_verb "$verb"
    local kind
    kind="$(verb_field "$verb" 1)"
    if [ "$kind" = "boot" ]; then
        help_boot_verb "$(verb_field "$verb" 2)"
    else
        local snake
        snake="$(kebab_to_snake "$verb")"
        "verb_help_${snake}"
    fi
}

# Main verb dispatch. Routes by `kind`:
#   - boot   → dispatch_boot (mix task)
#   - rpc    → dispatch_rpc OR bespoke verb_<snake> for arg-taking verbs
#   - meta   → help (special-cased)
#   - attach → verb_remote_shell
#   - debug  → verb_open_db / verb_shell
dispatch() {
    if [ $# -eq 0 ]; then
        help_top
        exit 0
    fi
    local verb=$1
    shift
    [ -n "${VERBS[$verb]:-}" ] || die_unknown_verb "$verb"
    local kind snake
    kind="$(verb_field "$verb" 1)"
    snake="$(kebab_to_snake "$verb")"
    # Prefer a bespoke `verb_<snake>` function when one exists — that
    # handles arg-taking verbs (delete-visitor, remote-shell) and the
    # debug verbs (open-db, shell). Generic dispatchers handle the
    # nullary/conventional cases. The prefer-bespoke rule means adding
    # a future arg-taking RPC verb is one VERBS entry + one
    # verb_<snake>() function — no dispatch-table edit needed.
    if declare -F "verb_${snake}" >/dev/null; then
        "verb_${snake}" "$@"
        return
    fi
    case "$kind" in
        boot) dispatch_boot "$verb" "$@" ;;
        rpc)  dispatch_rpc  "$verb" "$@" ;;
        meta) dispatch_help "$@" ;;
        *)    die_unknown_verb "$verb" ;;
    esac
}

dispatch "$@"
