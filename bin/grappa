#!/usr/bin/env bash
# bin/grappa — host-side operator dispatcher.
#
# One verb per task. Run from any worktree of the grappa repo:
#
#   bin/grappa help                     list verbs
#   bin/grappa help <verb>              per-verb help
#   bin/grappa <verb> [args]            dispatch
#
# The container IS the runtime. Boot-time verbs (create-user,
# bind-network, etc.) delegate to mix tasks inside the container via
# scripts/mix.sh (which auto-detects MIX_ENV). Live-state verbs
# (delete-visitor, reap-visitors, list-*) and remote-shell attach to
# the live BEAM via Erlang distribution: `elixir --rpc-eval grappa@grappa`
# evaluates a `Grappa.Operator.<verb>(...)` expression on the running
# node (per T-2). Operator-side bookkeeping lives in lib/grappa/operator.ex
# so the bash dispatcher stays a thin shell — one feature, one code
# path, every door.
#
# Verb name policy: kebab-case on the command line, snake_case for the
# underlying mix task (grappa.create_user, etc.). Mapping is the
# `case` statement in dispatch() below.

set -euo pipefail

. "$(dirname "$0")/../scripts/_lib.sh"

# Test seam: bats overrides SCRIPTS_DIR to point at a tmpdir with
# fake scripts/mix.sh. Production calls inherit the real scripts/.
SCRIPTS_DIR="${SCRIPTS_DIR:-$SRC_ROOT/scripts}"

# --- helpers --------------------------------------------------------------

mix_task() {
    # Auto-detect MIX_ENV from the live container; scripts/mix.sh handles
    # the override flag if the operator wants explicit env. Boot-time
    # verbs typically run against the container the operator is deploying
    # against, so auto-detect is the right default.
    exec "$SCRIPTS_DIR/mix.sh" "$@"
}

# Run a Grappa.Operator expression on the live BEAM via Erlang dist.
# Same shape as `remote-shell --batch -e <expr>` — mirror T-2 exactly so
# the operator-verb surface and the introspection surface share one
# transport. The expression is evaluated on the REMOTE node (`--rpc-eval`),
# NOT on the client (`--remsh -e` would evaluate client-side, defeating
# the point of attaching to the live tree).
rpc_eval() {
    local expr=$1
    exec docker compose "${COMPOSE_ARGS[@]}" exec -T grappa sh -c \
        'exec elixir --sname "admin-$$" --cookie "$RELEASE_COOKIE" --rpc-eval grappa@grappa "$1"' \
        -- "$expr"
}

die_unknown_verb() {
    printf 'bin/grappa: unknown verb %q\n' "$1" >&2
    printf 'Run `bin/grappa help` for the full verb table.\n' >&2
    exit 64
}

# --- per-verb implementations --------------------------------------------

# Boot-time verbs — thin delegates to existing mix tasks.

verb_create_user()                { mix_task grappa.create_user "$@"; }
verb_bind_network()               { mix_task grappa.bind_network "$@"; }
verb_add_server()                 { mix_task grappa.add_server "$@"; }
verb_set_network_caps()           { mix_task grappa.set_network_caps "$@"; }
verb_unbind_network()             { mix_task grappa.unbind_network "$@"; }
verb_update_network_credential()  { mix_task grappa.update_network_credential "$@"; }
verb_seed_scrollback()            { mix_task grappa.seed_scrollback "$@"; }
verb_gen_encryption_key()         { mix_task grappa.gen_encryption_key "$@"; }
verb_gen_vapid()                  { mix_task grappa.gen_vapid "$@"; }
verb_remove_server()              { mix_task grappa.remove_server "$@"; }

# Live-state verbs — evaluate Grappa.Operator entry points on the live
# BEAM via --rpc-eval. Output is whatever Operator's IO.puts emits;
# --rpc-eval also echoes the expression's return value (typically `:ok`)
# after the puts output. Same precedent as remote-shell --batch.

verb_delete_visitor() {
    if [ $# -ne 1 ]; then
        printf 'Usage: bin/grappa delete-visitor <uuid>\n' >&2
        exit 64
    fi
    local id=$1
    rpc_eval "Grappa.Operator.delete_visitor!(\"$id\")"
}

verb_reap_visitors() {
    rpc_eval "Grappa.Operator.reap_visitors!()"
}

verb_list_sessions() {
    rpc_eval "Grappa.Operator.list_sessions_text!()"
}

verb_list_credentials() {
    rpc_eval "Grappa.Operator.list_credentials_text!()"
}

verb_list_visitors() {
    rpc_eval "Grappa.Operator.list_visitors_text!()"
}

verb_remote_shell() {
    # T-A2 / T-2: live-BEAM attach via Erlang distribution. Cookie is
    # sourced INSIDE the container's `sh -c` (no host needs to know it);
    # admin sname uses $$ for per-invocation uniqueness.
    #
    # Interactive uses `iex --remsh` (REPL attaches to the live node).
    # Batch uses `elixir --rpc-eval`: `iex --remsh -e "<expr>"` evaluates
    # the expression in the CLIENT node before attaching, defeating the
    # operator's intent (Process.list() returns 60-ish vergine procs
    # rather than the live tree's 140+). `--rpc-eval` evaluates on the
    # REMOTE node and prints the result, no shell attached.
    case "${1:-}" in
        --batch)
            shift
            if [ "${1:-}" != "-e" ] || [ -z "${2:-}" ]; then
                printf 'remote-shell --batch requires `-e <expr>`.\n' >&2
                printf 'Usage: bin/grappa remote-shell --batch -e <expr>\n' >&2
                exit 64
            fi
            rpc_eval "$2"
            ;;
        "")
            exec docker compose "${COMPOSE_ARGS[@]}" exec grappa sh -c \
                'exec iex --sname "admin-$$" --cookie "$RELEASE_COOKIE" --remsh grappa@grappa'
            ;;
        *)
            printf 'remote-shell: unknown arg %q\n' "$1" >&2
            printf 'Usage: bin/grappa remote-shell [--batch -e <expr>]\n' >&2
            exit 64
            ;;
    esac
}

# Debug verbs — direct docker compose exec.

verb_open_db() {
    # WARNING: opens RW. scripts/db.sh is the ambient-safe RO alternative
    # for casual prod queries. Auto-detects active env's DB file via the
    # shared _lib.sh probe (single source of truth with scripts/mix.sh).
    local env db
    env="$(detect_mix_env)"
    env="${env:-dev}"
    db="/app/runtime/grappa_${env}.db"
    exec docker compose "${COMPOSE_ARGS[@]}" exec grappa sqlite3 "$db" "$@"
}

verb_shell() {
    exec docker compose "${COMPOSE_ARGS[@]}" exec grappa bash
}

# --- per-verb help -------------------------------------------------------
#
# Boot verbs delegate to `mix help grappa.<task>` (mix's built-in reads
# @shortdoc/@moduledoc). Live-state + debug verbs have inline heredocs.

help_boot_verb() {
    local task=$1
    exec "$SCRIPTS_DIR/mix.sh" --env=dev help "$task"
}

verb_help_create_user()                { help_boot_verb grappa.create_user; }
verb_help_bind_network()               { help_boot_verb grappa.bind_network; }
verb_help_add_server()                 { help_boot_verb grappa.add_server; }
verb_help_set_network_caps()           { help_boot_verb grappa.set_network_caps; }
verb_help_unbind_network()             { help_boot_verb grappa.unbind_network; }
verb_help_update_network_credential()  { help_boot_verb grappa.update_network_credential; }
verb_help_seed_scrollback()            { help_boot_verb grappa.seed_scrollback; }
verb_help_gen_encryption_key()         { help_boot_verb grappa.gen_encryption_key; }
verb_help_gen_vapid()                  { help_boot_verb grappa.gen_vapid; }
verb_help_remove_server()              { help_boot_verb grappa.remove_server; }

verb_help_delete_visitor() { cat <<'EOF'
delete-visitor <uuid>
    Synchronously terminate the visitor's Session.Server and delete
    the DB row, freeing the SessionRegistry cap slot in the same call.
    CASCADE wipes visitor_channels, messages, accounts_sessions,
    query_windows, push_subscriptions, user_settings, read_cursors.

    Unknown uuid: raises Ecto.NoResultsError; bin/grappa exits non-zero.
EOF
}

verb_help_reap_visitors() { cat <<'EOF'
reap-visitors
    Force-run Grappa.Visitors.Reaper.sweep/0 on demand. The scheduled
    tick runs every 60s; this verb is the operator-on-demand variant.
EOF
}

verb_help_list_sessions() { cat <<'EOF'
list-sessions
    Print every live Session.Server in Grappa.SessionRegistry as a
    tab-separated table. Columns:
        subject_kind  subject_id  network_id  pid  alive  mailbox_len  memory_kb
    The mailbox_len + memory_kb columns surface bloat / leaks on a
    stuck session.
EOF
}

verb_help_list_credentials() { cat <<'EOF'
list-credentials
    Print every bound (user, network) credential as a tab-separated
    table. Columns:
        user_id  network_slug  nick  state  connection_state_reason
EOF
}

verb_help_list_visitors() { cat <<'EOF'
list-visitors
    Print every active visitor as a tab-separated table. Columns:
        id  nick  network_slug  expires_at  identified  inserted_at
    Active = identified (never expires) OR anon with expires_at > now.
EOF
}

verb_help_remote_shell() { cat <<'EOF'
remote-shell [--batch -e <expr>]
    Attach to the live BEAM via Erlang distribution.

    Interactive (default — `iex --remsh`):
        bin/grappa remote-shell

    Batch (`elixir --rpc-eval`; eval one expression on the REMOTE
    node and exit):
        bin/grappa remote-shell --batch -e 'Process.list() |> length()'

    Note: `iex --remsh -e <expr>` evaluates in the CLIENT node
    BEFORE attaching the shell, which defeats `Process.list()` /
    `:sys.get_state(...)` / etc. — the point of remote-shell is to
    introspect the LIVE supervisor tree. `--rpc-eval` runs on the
    remote and prints the result.

    Distribution is internal to the container's network namespace —
    no host port is exposed. RELEASE_COOKIE is sourced from the
    container's environment (see compose.yaml + .env.example) and
    gates `iex --remsh` access. Anyone with `docker exec` privilege
    on the host can already read the cookie via `printenv`, AND any
    container attached to the `grappa_internal` bridge with Erlang
    installed could connect if it knew the cookie. The cookie is a
    same-host operator gate (sname-collision-prevention + "you
    meant to do this") rather than a network boundary.
EOF
}

verb_help_open_db() { cat <<'EOF'
open-db [sqlite3 args...]
    Open an interactive sqlite3 shell against the active env's DB
    inside the container. Detects MIX_ENV from the running container.

    WARNING: RW. Use scripts/db.sh for ambient-safe RO access.
EOF
}

verb_help_shell() { cat <<'EOF'
shell
    Drop into a bash shell inside the running grappa container.
    Requires the container to be up.
EOF
}

verb_help_help() { cat <<'EOF'
help [verb]
    With no arg, print the verb table grouped by category.
    With a verb, print that verb's help text.
EOF
}

# --- top-level help banner -----------------------------------------------

help_top() {
    cat <<'EOF'
bin/grappa — host-side operator dispatcher

Usage:
    bin/grappa <verb> [args...]
    bin/grappa help [verb]

Boot-time verbs (mix tasks; auto-detect MIX_ENV from container):
    create-user                  create a Grappa user account
    bind-network                 bind a (user, network) credential
    add-server                   add a server entry to a network
    remove-server                remove a server entry from a network
    set-network-caps             set per-network session caps
    unbind-network               remove a (user, network) credential
    update-network-credential    edit autojoin / nick / SASL fields
    seed-scrollback              seed dev scrollback
    gen-encryption-key           generate a Cloak.Vault key
    gen-vapid                    generate a VAPID keypair (push)

Live-state verbs (--rpc-eval against the live BEAM):
    delete-visitor <uuid>        terminate + delete a visitor (sync)
    reap-visitors                force-run the visitor reaper
    list-sessions                inspect the live session registry
    list-credentials             list cred bindings + state
    list-visitors                list active visitor rows

Live-state attach:
    remote-shell [--batch -e]    iex --remsh against the live BEAM

Debug verbs:
    open-db [args]               interactive sqlite3 against active env (RW)
    shell                        bash inside the grappa container

Meta:
    help [verb]                  this banner / per-verb help

EOF
}

# --- dispatch ------------------------------------------------------------

dispatch_help() {
    if [ $# -eq 0 ]; then
        help_top
        exit 0
    fi
    local verb=$1
    case "$verb" in
        create-user)                verb_help_create_user;;
        bind-network)               verb_help_bind_network;;
        add-server)                 verb_help_add_server;;
        set-network-caps)           verb_help_set_network_caps;;
        unbind-network)             verb_help_unbind_network;;
        update-network-credential)  verb_help_update_network_credential;;
        seed-scrollback)            verb_help_seed_scrollback;;
        gen-encryption-key)         verb_help_gen_encryption_key;;
        gen-vapid)                  verb_help_gen_vapid;;
        remove-server)              verb_help_remove_server;;
        delete-visitor)             verb_help_delete_visitor;;
        reap-visitors)              verb_help_reap_visitors;;
        list-sessions)              verb_help_list_sessions;;
        list-credentials)           verb_help_list_credentials;;
        list-visitors)              verb_help_list_visitors;;
        remote-shell)               verb_help_remote_shell;;
        open-db)                    verb_help_open_db;;
        shell)                      verb_help_shell;;
        help)                       verb_help_help;;
        *)                          die_unknown_verb "$verb";;
    esac
}

dispatch() {
    if [ $# -eq 0 ]; then
        help_top
        exit 0
    fi
    local verb=$1
    shift
    case "$verb" in
        help)                       dispatch_help "$@";;
        create-user)                verb_create_user "$@";;
        bind-network)               verb_bind_network "$@";;
        add-server)                 verb_add_server "$@";;
        set-network-caps)           verb_set_network_caps "$@";;
        unbind-network)             verb_unbind_network "$@";;
        update-network-credential)  verb_update_network_credential "$@";;
        seed-scrollback)            verb_seed_scrollback "$@";;
        gen-encryption-key)         verb_gen_encryption_key "$@";;
        gen-vapid)                  verb_gen_vapid "$@";;
        remove-server)              verb_remove_server "$@";;
        delete-visitor)             verb_delete_visitor "$@";;
        reap-visitors)              verb_reap_visitors "$@";;
        list-sessions)              verb_list_sessions "$@";;
        list-credentials)           verb_list_credentials "$@";;
        list-visitors)              verb_list_visitors "$@";;
        remote-shell)               verb_remote_shell "$@";;
        open-db)                    verb_open_db "$@";;
        shell)                      verb_shell "$@";;
        *)                          die_unknown_verb "$verb";;
    esac
}

dispatch "$@"
